// MODULE:  DEVICE.PRISMA
// ========================================

// prisma/modules/device.prisma

model Device {
  id String @id @default(cuid())

  userType AuthUserType @map("user_type")

  adminId String? @map("admin_id")
  admin   Admin?  @relation("AdminDevices", fields: [adminId], references: [id], onDelete: Cascade)

  customerId String?   @map("customer_id")
  customer   Customer? @relation("CustomerDevices", fields: [customerId], references: [id], onDelete: Cascade)


  deviceId   String  @map("device_id") @db.VarChar(191)
  deviceName String? @map("device_name") @db.VarChar(191)
  deviceType String? @map("device_type") @db.VarChar(50)

  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.Text

  isActive     Boolean   @default(true) @map("is_active")
  lastActiveAt DateTime  @default(now()) @map("last_active_at")
  revokedAt    DateTime? @map("revoked_at")

  createdAt    DateTime  @default(now()) @map("created_at")

  tokens AuthToken[]

  @@unique([userType, adminId, deviceId], name: "unique_admin_device")
  @@unique([userType, customerId, deviceId], name: "unique_customer_device")

  @@unique([adminId, deviceId])
  @@unique([customerId, deviceId])
  @@index([adminId])
  @@index([customerId])
  @@index([isActive])
  @@map("devices")
}


// ========================================
// MODULE:  DIVISION.PRISMA
// ========================================

model Division {
  id String @id @default(cuid())

  name   String @db.VarChar(191)
  slug String @unique

  position Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  cities    City[]
  addresses Address[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([isActive])
  @@index([deletedAt])
  @@map("divisions")
}


