// ========================================
// MODULE:  FLASH_SALE.PRISMA
// ========================================

model FlashSale {
  id String @id @default(cuid())

  name        String  @db.VarChar(191)
  description String? @db.Text

  // Sale timing
  startTime DateTime @map("start_time") // NEW: Renamed from validFrom
  endTime   DateTime @map("end_time")   // NEW: Renamed from validTo

  // Status
  status FlashSaleStatus @default(SCHEDULED) // NEW: Explicit status

  discountType  String // 'FIXED', 'PERCENT'
  discountValue Decimal @map("discount_value") @db.Decimal(12, 2)

  translations Json? @db.JsonB
  isActive Boolean @default(true) @map("is_active")

  products FlashSaleProduct[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([deletedAt])
  @@index([createdAt])
  @@index([status, startTime, endTime]) // NEW: For active sales queries
  @@index([isActive, status]) // NEW
  @@map("flash_sales")
}


// ========================================
// MODULE:  FLASH_SALE_PRODUCT.PRISMA
// ========================================

model FlashSaleProduct {
  id String @id @default(cuid())

  flashSaleId String    @map("flash_sale_id")
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  productVariantId String? @map("product_variant_id") // NEW: Support variant-level sales

  endDate  DateTime @map("end_date")
  price    Decimal  @db.Decimal(18, 4)

  // Stock management
  qty      Int
  sold     Int      @default(0)
  reserved Int      @default(0) // NEW: Reserved stock during checkout

  position Int      @default(0)

  // Status
  isActive Boolean @default(true) @map("is_active") // NEW

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@unique([flashSaleId, productId, productVariantId]) // NEW: Include variant
  @@index([flashSaleId])
  @@index([productId])
  @@index([productVariantId]) // NEW
  @@index([endDate])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([isActive, endDate]) // NEW: For active products
  @@index([flashSaleId, isActive]) // NEW
  @@map("flash_sale_products")
}


// ========================================
// MODULE:  INVENTORY_LOG.PRISMA
// ========================================

model InventoryLog {
  id String @id @default(cuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  productVariantId String?         @map("product_variant_id")
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  sku String? @db.VarChar(100)

  // Link to triggering order
  orderId String? @map("order_id")

  // NEW: Link to flash sale
  flashSaleProductId String? @map("flash_sale_product_id")

  reason InventoryReason @default(MANUAL_ADJUSTMENT)

  qtyBefore Int @map("qty_before") // Renamed from stockBefore
  qtyChange Int @map("qty_change") // Renamed from quantity
  qtyAfter  Int @map("qty_after")  // Renamed from stockAfter

  reference String? @db.VarChar(100)
  notes     String? @db.VarChar(500)
  changedBy String? @map("changed_by")

  metadata Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([productVariantId])
  @@index([orderId])
  @@index([flashSaleProductId]) // NEW
  @@index([reason])
  @@index([createdAt])
  @@index([productId, createdAt]) // NEW: For product history
  @@map("inventory_logs")
}


// ========================================
// MODULE:  MEDIA.PRISMA
// ========================================

model Media {
  id String @id @default(cuid())

  // file info
  filename     String @db.VarChar(191)
  originalName String @map("original_name") @db.VarChar(191)
  mimeType     String @map("mime_Type") @db.VarChar(100)
  size         Int
  extension    String @db.VarChar(20)

  // ! storage
  storageDriver String @map("storage_driver") @db.VarChar(20) //local || cloudinary
  storagePath   String @map("storage_path") @db.VarChar(500)
  storageUrl    String @map("storage_url") @db.VarChar(500)

  variants Json? @db.JsonB

  // ! image metadata
  width  Int?
  height Int?
  alt    String? @db.VarChar(191)

  // Reference tracking (how many entities use this media)
  referenceCount Int @default(0) @map("reference_count")

  // Polymorphic relations
  entityMedia EntityMedia[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  // Soft delete
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([storageDriver])
  @@index([mimeType])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([referenceCount])
  // @@index([referenceCount])
  @@index([storageDriver, deletedAt])
  @@map("media")
}

// ─── EntityMedia (Polymorphic Junction) ──────────────────────
// Links media to any entity: Product, Category, Brand, Tag, Admin, Customer

model EntityMedia {
  id String @id @default(cuid())

  // Polymorphic relation
  entityType String @map("entity_type") @db.VarChar(50) // 'Product', 'Category', 'Brand', 'Tag', 'Admin', 'Customer'
  entityId   String @map("entity_id")

  // Media
  mediaId String @map("media_id")
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  // Ordering & purpose
  position Int     @default(0) // For gallery ordering
  purpose  String? @db.VarChar(50) // 'gallery', 'thumbnail', 'icon', 'banner', 'logo', 'avatar'
  isMain   Boolean @default(false) @map("is_main") // Mark as main/primary image

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([entityType, entityId, mediaId]) // Prevent duplicate links
  @@index([entityType, entityId])
  @@index([mediaId])
  @@index([isMain])
  @@map("entity_media")
}


// ========================================
// MODULE:  NOTIFICATION.PRISMA
// ========================================

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  WEBHOOK
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

model Notification {
  id String @id @default(cuid())

  userId  String?             @map("user_id")
  channel NotificationChannel
  status  NotificationStatus  @default(QUEUED)
  data    Json                @db.JsonB

  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  failedAt    DateTime? @map("failed_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}


// ========================================
// MODULE:  ORDER.PRISMA
// ========================================

model Order {
  id String @id @default(cuid())

  orderNumber Int @unique @default(autoincrement()) @map("order_number")

  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Customer snapshot
  customerEmail     String  @map("customer_email") @db.VarChar(191)
  customerPhone     String? @map("customer_phone") @db.VarChar(50)
  customerFirstName String  @map("customer_first_name") @db.VarChar(191)
  customerLastName  String  @map("customer_last_name") @db.VarChar(191)

  // Address snapshot (JSON = immutable copy)
  shippingAddress Json @map("shipping_address") @db.JsonB
  billingAddress  Json @map("billing_address") @db.JsonB

  // Delivery info
  deliveryZoneId String? @map("delivery_zone_id")
  deliveryZone   DeliveryZone? @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)

  courierId      String? @map("courier_id")
  courierName    String? @map("courier_name") @db.VarChar(100)
  trackingNumber String? @map("tracking_number")

  // Money breakdown
  subTotal     Decimal @map("sub_total") @db.Decimal(18, 4)
  shippingCost Decimal @default(0) @map("shipping_cost") @db.Decimal(18, 4)
  discount     Decimal @default(0) @db.Decimal(18, 4)
  taxTotal     Decimal @default(0) @map("tax_total") @db.Decimal(18, 4)
  total        Decimal @db.Decimal(18, 4)

  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")

  // Coupon snapshot
  couponId            String?             @map("coupon_id")
  couponCode          String?             @map("coupon_code") @db.VarChar(191)
  couponDiscountType  CouponDiscountType? @map("coupon_discount_type")
  couponDiscountValue Decimal?            @map("coupon_discount_value") @db.Decimal(18, 4)

  currency     String  @default("BDT") @db.VarChar(10)
  currencyRate Decimal @default(1) @map("currency_rate") @db.Decimal(18, 4)

  status OrderStatus @default(PENDING)

  notes     Json?   @db.JsonB
  locale    String  @default("bn-BD") @db.VarChar(10)
  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(500)

  shippedAt   DateTime? @map("shipped_at")
  deliveredAt DateTime? @map("delivered_at")
  canceledAt  DateTime? @map("canceled_at")
  refundedAt    DateTime? @map("refunded_at")

  products      OrderProduct[]
  taxes         OrderTax[]
  statusHistory OrderStatusHistory[]
  packages      OrderPackage[]
  transaction   Transaction?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([paymentMethod])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("orders")
}


// ========================================
// MODULE:  ORDER.TAX.PRISMA
// ========================================

model OrderTax {
  id String @id @default(cuid())

  orderId   String  @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id])
  taxRateId String  @map("tax_rate_id")
  taxRate   TaxRate @relation(fields: [taxRateId], references: [id])


  amount    Decimal @db.Decimal(15, 4)
  rateName  String  @map("rate_name") @db.VarChar(191)
  rateValue Decimal @map("rate_value") @db.Decimal(8, 4)

  // @@id([orderId, taxRateId])
  @@index([taxRateId])
  @@map("order_taxes")
}


// ========================================
// MODULE:  ORDER_PRODUCT.PRISMA
// ========================================

model OrderProduct {
  id String @id @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  productVariantId String?         @map("product_variant_id")
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  productName String  @map("product_name") @db.VarChar(191)
  productSku  String? @map("product_sku") @db.VarChar(100)
  productSlug String  @map("product_slug") @db.VarChar(191)

  productImage Json? @map("product_image") @db.JsonB

  unitPrice Decimal @map("unit_price") @db.Decimal(18, 4)
  qty       Int
  lineTotal Decimal @map("line_total") @db.Decimal(18, 4)

  options OrderProductOption[]
  variations OrderProductVariation[]

  @@index([orderId])
  @@index([productId])
  @@map("order_products")
}


// ========================================
// MODULE:  ORDER_PRODUCT_DETAILS.PRISMA
// ========================================

model OrderProductOption {
  id String @id @default(cuid())

  orderProductId String       @map("order_product_id")
  orderProduct   OrderProduct @relation(fields: [orderProductId], references: [id])

  optionName String  @map("option_name") @db.VarChar(191)
  value      String? @db.Text
  values OrderProductOptionValue[]

  @@unique([orderProductId, optionName])
  @@map("order_product_options")
}

model OrderProductOptionValue {
  id String @id @default(cuid())

  orderProductOptionId String             @map("order_product_option_id")
  orderProductOption   OrderProductOption @relation(fields: [orderProductOptionId], references: [id])


  label String   @db.VarChar(191)
  price Decimal? @db.Decimal(18, 4)

  @@map("order_product_option_values")
}

model OrderProductVariation {
  id String @id @default(cuid())

  orderProductId String       @map("order_product_id")
  orderProduct   OrderProduct @relation(fields: [orderProductId], references: [id])

  variationName String        @map("variation_name") @db.VarChar(191)
  type          VariationType
  value         String        @db.VarChar(191)

  variationValues OrderProductVariationValue[]
  

  @@unique([orderProductId, variationName])
  @@map("order_product_variations")
}

model OrderProductVariationValue {
  orderProductVariationId String                @map("order_product_variation_id")
  orderProductVariation   OrderProductVariation @relation(fields: [orderProductVariationId], references: [id])

  variationValueId String         @map("variation_value_id")
  variationValue   VariationValue @relation(fields: [variationValueId], references: [id])

  @@id([orderProductVariationId, variationValueId])
  @@index([variationValueId])
  @@map("order_product_variation_values")
}


// ========================================
// MODULE:  ORDER_STATUS_HISTORY.PRISMA
// ========================================

model OrderStatusHistory {
  id String @id @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fromStatus OrderStatus? @map("from_status") // null for initial creation
  toStatus   OrderStatus  @map("to_status")
  metadata Json? @db.JsonB

  // IMMUTABLE
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([toStatus])
  @@index([createdAt])
  @@map("order_status_history")
}


// ========================================
// MODULE:  OTP.PRISMA
// ========================================

model OTP {
  id String @id @default(cuid())

  phone     String  @db.VarChar(20)
  code      String  @db.VarChar(10)
  type      String  // 'PHONE_VERIFICATION', 'LOGIN', 'PASSWORD_RESET'
  attempts  Int     @default(0)

