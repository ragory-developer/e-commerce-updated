// ─── UPDATED Address model ───────────────────────────────────
// Now supports BD location hierarchy while keeping backward compat

model Address {
  id String @id @default(cuid())

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label        String? @db.VarChar(50) // "Home", "Office"
  fullName     String  @map("full_name") @db.VarChar(191)
  phone        String  @db.VarChar(50)
  addressLine  String  @map("address_line") @db.Text  // Full street address

  // BD Location refs (nullable for backward compat)
  divisionId String? @map("division_id")
  cityId     String? @map("city_id")
  areaId     String? @map("area_id")

  // Denormalized for display + order snapshot (so we don't need joins)
  division   String  @db.VarChar(100) // "Dhaka"
  city       String  @db.VarChar(100) // "Dhaka"
  area       String  @db.VarChar(150) // "Dhanmondi"
  postalCode String  @map("postal_code") @db.VarChar(10) // "1205"
  country    String  @default("BD") @db.VarChar(50)

  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([customerId])
  @@index([areaId])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("addresses")
}
