model ProductCategory {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  position Int @default(0) // NEW: Manual ordering within category
  isPrimary Boolean @default(false) @map("is_primary") // NEW: Primary category

  @@unique([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
  @@index([categoryId, position]) // NEW: For ordered category listings
  @@index([categoryId, isPrimary]) // NEW
  @@map("product_categories")
}
