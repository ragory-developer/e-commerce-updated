model Product {
  id String @id @default(cuid())

  brandId String? @map("brand_id")
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  taxClassId String?   @map("tax_class_id")
  taxClass   TaxClass? @relation(fields: [taxClassId], references: [id], onDelete: SetNull)

  name             String  @db.VarChar(191)
  slug             String  @unique @db.VarChar(191)
  description      String  @db.Text
  shortDescription String? @map("short_description") @db.Text
  sku              String? @unique @db.VarChar(100)

  // Pricing
  price             Decimal?          @db.Decimal(18, 4)
  specialPrice      Decimal?          @map("special_price") @db.Decimal(18, 4)
  specialPriceType  SpecialPriceType? @map("special_price_type")
  specialPriceStart DateTime?         @map("special_price_start")
  specialPriceEnd   DateTime?         @map("special_price_end")

  // NEW: Price range for products with variants
  minPrice Decimal? @map("min_price") @db.Decimal(18, 4)
  maxPrice Decimal? @map("max_price") @db.Decimal(18, 4)

  // Inventory
  manageStock Boolean @default(false) @map("manage_stock")
  qty         Int?
  inStock     Boolean @default(true) @map("in_stock")

  // NEW: Low stock alert
  lowStockThreshold Int? @map("low_stock_threshold")

  // Shipping
  weight Decimal? @db.Decimal(10, 2)
  length String   @db.VarChar(100)
  width  String   @db.VarChar(100)
  height String   @db.VarChar(100)

  // Flags
  isActive   Boolean @default(true) @map("is_active")
  isFeatured Boolean @default(false) @map("is_featured") // NEW
  viewed     Int     @default(0)

  // NEW: Rating system
  averageRating Decimal? @map("average_rating") @db.Decimal(3, 2) // 0.00 to 5.00
  reviewCount   Int      @default(0) @map("review_count")

  newFrom DateTime? @map("new_from")
  newTo   DateTime? @map("new_to")

  // Media
  images    Json? @db.JsonB
  downloads Json? @db.JsonB

  // i18n + SEO
  translations Json? @db.JsonB
  seo          Json? @db.JsonB

  // Relations
  categories        ProductCategory[]
  tags              ProductTag[]
  attributes        ProductAttribute[]
  variations        ProductVariation[]
  variants          ProductVariant[]
  reviews           Review[]
  orderProducts     OrderProduct[]
  relatedTo         RelatedProduct[]   @relation("ProductRelated")
  relatedFrom       RelatedProduct[]   @relation("RelatedToProduct")
  upSellTo          UpSellProduct[]    @relation("ProductUpSell")
  upSellFrom        UpSellProduct[]    @relation("UpSellToProduct")
  crossSellTo       CrossSellProduct[] @relation("ProductCrossSell")
  crossSellFrom     CrossSellProduct[] @relation("CrossSellToProduct")
  flashSaleProducts FlashSaleProduct[]
  couponProducts    CouponProduct[]

  // Soft Delete
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  createdBy     String?        @map("created_by")
  updatedBy     String?        @map("updated_by")
  deletedAt     DateTime?      @map("deleted_at")
  deletedBy     String?        @map("deleted_by")
  inventoryLogs InventoryLog[]
  // wishlistItems WishlistItem[]

  @@index([brandId])
  @@index([taxClassId])
  @@index([slug])
  @@index([sku])
  @@index([isActive, deletedAt])
  @@index([price])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([viewed]) // NEW
  @@index([averageRating]) // NEW
  @@index([isFeatured, isActive]) // NEW
  @@index([minPrice, maxPrice]) // NEW: For price range queries
  @@index([isActive, isFeatured, averageRating]) // NEW: Composite for featured products
  @@map("products")
}
