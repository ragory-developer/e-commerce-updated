model SearchTerm {
  id String @id @default(cuid())

  term  String @db.VarChar(191)
  count Int    @default(1)
  lastUsedAt DateTime @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([term])
  @@index([term])
  @@index([count])
  @@index([lastUsedAt])
  @@map("search_terms")
}
